<mujoco model="tactile_vault_v2">
  <compiler angle="degree" autolimits="true"/>
  <option timestep="0.004" gravity="0 0 -9.81" integrator="implicitfast" cone="elliptic">
    <flag contact="enable"/>
  </option>
  <size njmax="4000" nconmax="800"/>

  <visual>
    <global offwidth="960" offheight="540"/>
    <headlight ambient="0.38 0.38 0.42" diffuse="0.78 0.78 0.78" specular="0.25 0.25 0.25"/>
    <rgba haze="0.06 0.08 0.12 1"/>
  </visual>

  <default>
    <joint damping="2" armature="0.01"/>
    <geom friction="1.6 0.02 0.002" condim="4" solref="0.008 1" solimp="0.92 0.97 0.002"/>
    <position kp="150" kv="18"/>
    <default class="digit">
      <joint type="slide" range="0 0.055" damping="4"/>
      <geom type="capsule" fromto="0 0 -0.030 0 0 0.030" size="0.015"
            rgba="0.15 0.78 0.92 1" friction="3.5 0.04 0.003"/>
      <site type="ellipsoid" size="0.026 0.026 0.055" rgba="0.05 1 0.75 0.18"/>
    </default>
    <default class="key">
      <joint type="slide" axis="0 0 -1" range="0 0.022" stiffness="180" damping="3"/>
      <geom type="cylinder" size="0.028 0.012" mass="0.025" friction="2.2 0.02 0.002"/>
      <site type="cylinder" size="0.034 0.035" rgba="1 1 1 0.12"/>
    </default>
  </default>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="256" height="256"
             rgb1="0.08 0.10 0.15" rgb2="0.14 0.18 0.24"/>
    <material name="floor_mat" texture="grid" texrepeat="10 10" reflectance="0.12"/>
    <material name="vault_mat" rgba="0.23 0.27 0.35 1" metallic="0.55" roughness="0.42"/>
    <material name="vial_mat" rgba="0.96 0.40 0.10 1"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1" material="floor_mat"/>
    <light pos="0 -1.5 2.5" dir="0 0.5 -1"/>
    <light pos="-1 1 1.8" dir="0.5 -0.4 -1" diffuse="0.35 0.55 0.80"/>

    <!-- The lockbox is a real obstacle: the lid covers the vial until the
         measured tactile code releases lid_lock and the hand pushes it. -->
    <body name="vault" pos="0.18 0.08 0.04">
      <geom name="vault_base" type="box" size="0.25 0.22 0.04" material="vault_mat"/>
      <geom name="vault_left_wall" type="box" pos="-0.235 0 0.10" size="0.015 0.22 0.10" material="vault_mat"/>
      <geom name="vault_right_wall" type="box" pos="0.235 0 0.10" size="0.015 0.22 0.10" material="vault_mat"/>
      <geom name="vault_back_wall" type="box" pos="0 0.205 0.10" size="0.25 0.015 0.10" material="vault_mat"/>
      <geom name="well_floor" type="cylinder" pos="0 0 0.055" size="0.058 0.015" rgba="0.08 0.10 0.14 1"/>
      <site name="vault_center" pos="0 0 0.14" size="0.008" rgba="0 0 0 0"/>
    </body>

    <!-- Three different raised patterns can be located by touch. The code is
         triangle -> bars -> dot (key 1 -> key 3 -> key 2). -->
    <body name="key_1" pos="-0.02 -0.27 0.15" childclass="key">
      <joint name="key_1_slide"/><geom name="key_1_geom" rgba="0.98 0.56 0.12 1"/>
      <geom type="box" pos="0 0 0.015" size="0.018 0.004 0.005" euler="0 0 0" mass="0.001" rgba="1 0.9 0.5 1"/>
      <geom type="box" pos="0 0 0.015" size="0.018 0.004 0.005" euler="0 0 60" mass="0.001" rgba="1 0.9 0.5 1"/>
      <geom type="box" pos="0 0 0.015" size="0.018 0.004 0.005" euler="0 0 -60" mass="0.001" rgba="1 0.9 0.5 1"/>
      <site name="key_1_touch_site"/>
    </body>
    <body name="key_2" pos="0.10 -0.27 0.15" childclass="key">
      <joint name="key_2_slide"/><geom name="key_2_geom" rgba="0.25 0.72 1 1"/>
      <geom type="sphere" pos="0 0 0.018" size="0.009" mass="0.001" rgba="0.75 0.94 1 1"/>
      <site name="key_2_touch_site"/>
    </body>
    <body name="key_3" pos="0.22 -0.27 0.15" childclass="key">
      <joint name="key_3_slide"/><geom name="key_3_geom" rgba="0.72 0.42 1 1"/>
      <geom type="box" pos="-0.010 0 0.017" size="0.004 0.018 0.005" mass="0.001" rgba="0.95 0.82 1 1"/>
      <geom type="box" pos="0.010 0 0.017" size="0.004 0.018 0.005" mass="0.001" rgba="0.95 0.82 1 1"/>
      <site name="key_3_touch_site"/>
    </body>

    <body name="lid" pos="0.18 0.08 0.290">
      <joint name="lid_slide" type="slide" axis="1 0 0" range="0 0.42" damping="5" frictionloss="0.4"/>
      <geom name="lid_panel" type="box" size="0.25 0.22 0.018" material="vault_mat" mass="0.7"/>
      <geom name="lid_handle" type="box" pos="-0.18 -0.02 0.055" size="0.025 0.075 0.045"
            rgba="0.94 0.20 0.12 1" friction="3 0.03 0.002"/>
      <site name="lid_handle_touch_site" type="ellipsoid" pos="-0.18 -0.02 0.055" size="0.05 0.10 0.07" rgba="1 0.1 0.1 0.15"/>
    </body>

    <body name="medicine_vial" pos="0.18 0.08 0.180">
      <freejoint name="vial_free"/>
      <geom name="vial_body" type="cylinder" size="0.036 0.070" material="vial_mat" mass="0.10"
            friction="4.0 0.05 0.005"/>
      <geom name="vial_cap" type="cylinder" pos="0 0 0.078" size="0.039 0.010"
            rgba="0.92 0.96 1 1" mass="0.02" friction="4.0 0.05 0.005"/>
      <site name="vial_site" size="0.010" rgba="1 1 1 0.35"/>
    </body>

    <site name="delivery_goal" pos="-0.462 0.015 0.122" size="0.055" rgba="0.10 1 0.35 0.35"/>
    <geom name="delivery_pad" type="cylinder" pos="-0.43 0.02 0.012" size="0.095 0.012" rgba="0.08 0.68 0.28 1"/>
    <geom name="tray_left" type="box" pos="-0.49 0.02 0.045" size="0.010 0.070 0.045" rgba="0.08 0.82 0.35 1"/>
    <geom name="tray_right" type="box" pos="-0.37 0.02 0.045" size="0.010 0.070 0.045" rgba="0.08 0.82 0.35 1"/>
    <geom name="tray_front" type="box" pos="-0.43 -0.04 0.045" size="0.050 0.010 0.045" rgba="0.08 0.82 0.35 1"/>
    <geom name="tray_back" type="box" pos="-0.43 0.08 0.045" size="0.050 0.010 0.045" rgba="0.08 0.82 0.35 1"/>

    <!-- A compact five-digit radial hand. Each digit has an independent
         prismatic close joint, tactile pad, and contact-only adhesion channel. -->
    <body name="gantry" pos="-0.32 -0.22 0.50">
      <inertial pos="0 0 0" mass="0.25" diaginertia="0.002 0.002 0.002"/>
      <joint name="hand_x" type="slide" axis="1 0 0" range="-0.35 0.85" damping="14"/>
      <joint name="hand_y" type="slide" axis="0 1 0" range="-0.35 0.65" damping="14"/>
      <joint name="hand_z" type="slide" axis="0 0 1" range="-0.42 0.20" damping="14"/>
      <body name="wrist">
        <joint name="wrist_yaw" type="hinge" axis="0 0 1" range="-180 180" damping="5"/>
        <geom type="cylinder" size="0.052 0.035" rgba="0.38 0.44 0.56 1" contype="0" conaffinity="0"/>
        <body name="palm" pos="0 0 -0.055">
          <geom name="palm_geom" type="cylinder" size="0.095 0.018" rgba="0.18 0.48 0.72 1" contype="0" conaffinity="0"/>
          <site name="palm_site" size="0.010"/>

          <body name="index_pad" pos="0.090 0 -0.100" childclass="digit">
            <joint name="index_close" axis="-1 0 0"/><geom name="index_pad_geom"/><site name="index_touch_site"/>
          </body>
          <body name="middle_pad" pos="0.028 0.086 -0.100" childclass="digit">
            <joint name="middle_close" axis="-0.309 -0.951 0"/><geom name="middle_pad_geom"/><site name="middle_touch_site"/>
          </body>
          <body name="ring_pad" pos="-0.073 0.053 -0.100" childclass="digit">
            <joint name="ring_close" axis="0.809 -0.588 0"/><geom name="ring_pad_geom"/><site name="ring_touch_site"/>
          </body>
          <body name="little_pad" pos="-0.073 -0.053 -0.100" childclass="digit">
            <joint name="little_close" axis="0.809 0.588 0"/><geom name="little_pad_geom"/><site name="little_touch_site"/>
          </body>
          <body name="thumb_pad" pos="0.028 -0.086 -0.100" childclass="digit">
            <joint name="thumb_close" axis="-0.309 0.951 0"/><geom name="thumb_pad_geom" rgba="0.12 0.94 0.68 1"/><site name="thumb_touch_site"/>
          </body>
        </body>
      </body>
    </body>

    <camera name="judge_camera" pos="1.15 -1.35 1.15" xyaxes="0.76 0.65 0 -0.37 0.43 0.82"/>
    <camera name="detail_camera" pos="0.55 -0.85 0.72" xyaxes="0.84 0.54 0 -0.27 0.42 0.87"/>
  </worldbody>

  <actuator>
    <position name="hand_x_servo" joint="hand_x" kp="700" kv="55"/>
    <position name="hand_y_servo" joint="hand_y" kp="700" kv="55"/>
    <position name="hand_z_servo" joint="hand_z" kp="700" kv="55"/>
    <position name="wrist_yaw_servo" joint="wrist_yaw" kp="120" kv="14"/>
    <position name="index_servo" joint="index_close" kp="260" kv="22"/>
    <position name="middle_servo" joint="middle_close" kp="260" kv="22"/>
    <position name="ring_servo" joint="ring_close" kp="260" kv="22"/>
    <position name="little_servo" joint="little_close" kp="260" kv="22"/>
    <position name="thumb_servo" joint="thumb_close" kp="260" kv="22"/>
    <adhesion name="index_adhesion" body="index_pad" gain="18" ctrlrange="0 1"/>
    <adhesion name="middle_adhesion" body="middle_pad" gain="18" ctrlrange="0 1"/>
    <adhesion name="ring_adhesion" body="ring_pad" gain="18" ctrlrange="0 1"/>
    <adhesion name="little_adhesion" body="little_pad" gain="18" ctrlrange="0 1"/>
    <adhesion name="thumb_adhesion" body="thumb_pad" gain="18" ctrlrange="0 1"/>
  </actuator>

  <!-- A solver lock is appropriate here: it models the physical lock, not the
       grasp. The controller may release it only after the measured key code. -->
  <equality>
    <weld name="lid_lock" body1="lid" body2="vault" active="true"
          solref="0.004 1" solimp="0.98 0.995 0.001"/>
  </equality>

  <sensor>
    <framepos name="palm_position" objtype="site" objname="palm_site"/>
    <framepos name="vial_position" objtype="site" objname="vial_site"/>
    <framepos name="goal_position" objtype="site" objname="delivery_goal"/>
    <jointpos name="hand_x_position" joint="hand_x"/><jointpos name="hand_y_position" joint="hand_y"/><jointpos name="hand_z_position" joint="hand_z"/>
    <jointpos name="key_1_depth" joint="key_1_slide"/><jointpos name="key_2_depth" joint="key_2_slide"/><jointpos name="key_3_depth" joint="key_3_slide"/>
    <jointpos name="lid_position" joint="lid_slide"/>
    <touch name="key_1_touch" site="key_1_touch_site"/><touch name="key_2_touch" site="key_2_touch_site"/><touch name="key_3_touch" site="key_3_touch_site"/>
    <touch name="lid_handle_touch" site="lid_handle_touch_site"/>
    <touch name="index_touch" site="index_touch_site"/><touch name="middle_touch" site="middle_touch_site"/>
    <touch name="ring_touch" site="ring_touch_site"/><touch name="little_touch" site="little_touch_site"/><touch name="thumb_touch" site="thumb_touch_site"/>
  </sensor>
</mujoco>
